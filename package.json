{
  "name": "obsidian-graphite-tasks",
  "version": "0.1.0",
  "description": "A minimal Todoist-like task manager using local Markdown files.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run test && npm run build"
  },
  "keywords": [
    "obsidian",
    "tasks",
    "todo"
  ],
  "author": "Real-Fruit-Snacks",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.12",
    "esbuild": "^0.23.0",
    "obsidian": "^1.7.2",
    "tslib": "^2.6.3",
    "typescript": "^5.5.3",
    "vitest": "^4.1.10"
  }
}
